{
  "name": "osls",
  "version": "3.40.1",
  "description": "Open-source alternative to Serverless Framework",
  "preferGlobal": true,
  "homepage": "https://github.com/oss-serverless/serverless",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oss-serverless/serverless.git"
  },
  "keywords": [
